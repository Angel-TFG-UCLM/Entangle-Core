# ==============================================
# VARIABLES DE ENTORNO PARA DESPLIEGUE EN AZURE
# ==============================================
# Copiar este archivo como .env y configurar los valores reales

# GitHub Configuration
# ---------------------
# Token de acceso personal de GitHub con permisos: repo, read:org, read:user
GITHUB_TOKEN=your_github_token_here

# MongoDB Configuration
# ---------------------
# URI de conexión a MongoDB (Azure CosmosDB con API MongoDB o MongoDB Atlas)
# Formato: mongodb://username:password@host:port/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=quantum_github

# Application Configuration
# -------------------------
# Entorno de ejecución: development, staging, production
ENVIRONMENT=production
DEBUG=False

# API Configuration (opcional - por defecto usa 0.0.0.0:8000)
# API_HOST=0.0.0.0
# API_PORT=8000

# Azure Configuration (opcional)
# ------------------------------
# Si usas Azure Key Vault para secretos
# AZURE_KEY_VAULT_NAME=your_keyvault_name

# Logging Configuration (opcional)
# ---------------------------------
# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application Insights (opcional)
# -------------------------------
# APPLICATIONINSIGHTS_CONNECTION_STRING=your_connection_string_here
