{
  "description": "Configuración de criterios de ingesta para repositorios de software cuántico",
  "version": "2.0",
  "keywords": [
    "quantum",
    "qiskit",
    "braket",
    "cirq",
    "pennylane",
    "quantum computing",
    "quantum algorithms",
    "quantum machine learning",
    "qml",
    "qubit",
    "quantum simulator",
    "quantum circuit"
  ],
  "languages": [
    "Python",
    "C++",
    "Q#",
    "Rust",
    "Julia",
    "JavaScript"
  ],
  "min_stars": 10,
  "max_inactivity_days": 365,
  "exclude_forks": true,
  "min_contributors": 1,
  "additional_filters": {
    "has_topics": true,
    "has_readme": true,
    "min_size_kb": 10
  },
  "enable_segmentation": true,
  "segmentation": {
    "stars": [
      [10, 49],
      [50, 99],
      [100, 499],
      [500, 999],
      [1000, 4999],
      [5000, 999999]
    ],
    "created_years": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025]
  },
  "github_search_limit": 1000,
  "rate_limit": {
    "check_before_request": true,
    "min_remaining": 100,
    "wait_on_exhaustion": true
  }
}
