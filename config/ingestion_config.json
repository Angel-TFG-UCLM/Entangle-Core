{
  "description": "Configuración de criterios de ingesta para repositorios de software cuántico",
  "version": "2.0",
  "keywords": [
    "quantum",
    "qiskit",
    "braket",
    "cirq",
    "pennylane",
    "quantum computing",
    "quantum algorithms",
    "quantum machine learning",
    "qml",
    "qubit",
    "quantum simulator",
    "quantum circuit",
    "quantum annealing",
    "quantum optimization",
    "quantum cryptography",
    "quantum teleportation",
    "quantum entanglement",
    "quantum superposition",
    "quantum gates",
    "quantum error correction",
    "quantum chemistry",
    "quantum mechanics",
    "quantum physics",
    "quantum programming",
    "quantum software",
    "quantum hardware",
    "quantum processor",
    "quantum computer",
    "qpu",
    "qaoa",
    "vqe",
    "quil",
    "openqasm",
    "qasm",
    "pyquil",
    "strawberry fields",
    "projectq",
    "quantum inspire",
    "quantum development kit",
    "forest",
    "rigetti",
    "ionq",
    "d-wave",
    "ibm quantum",
    "google quantum",
    "azure quantum",
    "aws quantum",
    "quantum supremacy",
    "quantum advantage",
    "nisq",
    "fault-tolerant",
    "topological quantum",
    "adiabatic quantum",
    "variational quantum",
    "hybrid quantum",
    "quantum neural network",
    "qnn",
    "quantum walk",
    "quantum fourier transform",
    "grover algorithm",
    "shor algorithm",
    "quantum key distribution",
    "qkd",
    "bell state",
    "ghz state",
    "bloch sphere",
    "density matrix",
    "quantum state",
    "quantum measurement",
    "quantum decoherence",
    "quantum noise"
  ],
  "languages": [
    "Python",
    "C++",
    "Q#",
    "Rust",
    "Julia",
    "JavaScript"
  ],
  "min_stars": 10,
  "max_inactivity_days": 365,
  "exclude_forks": true,
  "min_contributors": 1,
  "additional_filters": {
    "has_topics": true,
    "has_readme": true,
    "min_size_kb": 10
  },
  "enable_segmentation": true,
  "segmentation": {
    "stars": [
      [10, 49],
      [50, 99],
      [100, 499],
      [500, 999],
      [1000, 4999],
      [5000, 999999]
    ],
    "created_years": [2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025]
  },
  "github_search_limit": 1000,
  "rate_limit": {
    "check_before_request": true,
    "min_remaining": 100,
    "wait_on_exhaustion": true
  }
}
